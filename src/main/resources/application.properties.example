# Database Configuration
spring.datasource.url=jdbc:postgresql://localhost:5432/movie_booking
spring.datasource.username=postgres
spring.datasource.password=YOUR_PASSWORD_HERE

# JPA Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

# NOTE: DO NOT edit this file directly for local development.
# Instead, set environment variables:
#   Windows: set DB_USERNAME=postgres && set DB_PASSWORD=your_password
#   Linux/Mac: export DB_USERNAME=postgres && export DB_PASSWORD=your_password
